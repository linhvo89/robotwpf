## Ignore Visual Studio temporary files, build results, and files generated by popular Visual Studio add-ons.

# Folder structure
bin/
obj/
.vs/
.vscode/

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/

# NuGet
*.nupkg
*.snupkg
.nuget/

# Visual Studio cache/options
.vs/

# Rider
.idea/
*.sln.iml

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Test Results
[Tt]estResults/
*.trx
*.coverage

# Local environment variables
.env
appsettings.local.json
