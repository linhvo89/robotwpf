<Window x:Class="WpfCompanyApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WpfCompanyApp.ViewModels"
        xmlns:local="clr-namespace:WpfCompanyApp"
        Title="KBOT"
          Language="en-US"
        Height="900" Width="1700"
        WindowStartupLocation="CenterScreen"  WindowState="Maximized">


    <DockPanel LastChildFill="True" Background="#1E1E1E">
        <!-- 🔷 Thanh tiêu đề -->
        <!-- 🔷 Thanh tiêu đề hiện đại -->
        <Border DockPanel.Dock="Top"
        Height="90"
        Margin="0,0,0,10"
        CornerRadius="0,0,15,15"
        Padding="0">
            <!-- 🎨 Gradient nền tối cao cấp -->
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#1C1F26" Offset="0.0"/>
                    <GradientStop Color="#2A3F6F" Offset="0.5"/>
                    <!-- màu trung gian -->
           

                </LinearGradientBrush>

            </Border.Background>

            <!-- ✨ Bóng đổ nhẹ bên dưới -->
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="4" Opacity="0.45"/>
            </Border.Effect>

            <DockPanel>
                <!-- 🔹 Logo góc trái -->
                <StackPanel Orientation="Horizontal"
                    DockPanel.Dock="Left"
                    VerticalAlignment="Center"
                    Margin="20,0,0,0">
                    <Ellipse Width="36" Height="36" Fill="#2196F3" Opacity="0.9">
                        <Ellipse.Effect>
                            <DropShadowEffect Color="#000000"
                                      BlurRadius="8"
                                      ShadowDepth="2"
                                      Opacity="0.4"/>
                        </Ellipse.Effect>
                    </Ellipse>
                    <TextBlock Text="🤖"
                       FontSize="22"
                       VerticalAlignment="Center"
                       Margin="-28,0,0,0"/>
                </StackPanel>

                <!-- 🔷 Tiêu đề chính -->
                <TextBlock Text="Automatic Pick &amp; Place System"
                   FontSize="42"
                   FontWeight="Bold"
                   Foreground="#E3F2FD"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   TextOptions.TextFormattingMode="Display">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#000000"
                                  BlurRadius="8"
                                  ShadowDepth="1"
                                  Opacity="0.6"/>
                    </TextBlock.Effect>
                </TextBlock>
            </DockPanel>
        </Border>




        <!-- 🧭 Thanh chuyển tab bên trái -->
        <!-- 🧭 Thanh chuyển tab bên trái -->
        <!-- Sidebar gọn (Width=100) với ToolTip chắc chắn hiện -->
        <Border DockPanel.Dock="Left"
        Width="100"
        Margin="10,0,10,0"
        CornerRadius="10"
        Background="#2D2D2D">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="3" Opacity="0.4"/>
            </Border.Effect>

            <StackPanel Orientation="Vertical" VerticalAlignment="Top" Margin="5">
                <StackPanel.Resources>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#3A3A3A"/>
                        <Setter Property="Foreground" Value="#E0E0E0"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Margin" Value="0,4,0,4"/>
                        <Setter Property="Padding" Value="6"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="BorderBrush" Value="#4A4A4A"/>
                        <Setter Property="BorderThickness" Value="1"/>
                     
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="Width" Value="80"/>
                        <Setter Property="Height" Value="60"/>
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.25"/>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1976D2"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderBrush" Value="#2196F3"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1565C0"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Resources>

                <!-- Button Home -->
                <Button Command="{Binding GoHomeCommand}" FontSize="20">
                    <!-- bắt buộc dùng element để tooltip chắc chắn -->
                    <Button.ToolTip>
                        <TextBlock Text="Home" Padding="6,2"  FontSize="20"/>
                    </Button.ToolTip>
                    <!-- Tùy chọn: hiện icon + text (nếu muốn) -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="🏠" FontSize="32" Margin="0,0,4,0"/>
                        <!-- nếu muốn chữ hiển thị trong button, bỏ comment dòng dưới -->
                        <!-- <TextBlock Text="Home" FontSize="13" VerticalAlignment="Center"/> -->
                    </StackPanel>
                </Button>

                <!-- Button Settings -->
                <Button Command="{Binding GoSettingsCommand}" FontSize="20">
                    <ToolTipService.InitialShowDelay>0</ToolTipService.InitialShowDelay>
                    <Button.ToolTip>
                        <TextBlock Text="Settings" Padding="6,2" FontSize="20"/>
                    </Button.ToolTip>
                    <TextBlock Text="⚙️" HorizontalAlignment="Center" FontSize="32" />
                </Button>

                <!-- Button Manual -->
                <Button Command="{Binding GoManualCommand}" FontSize="20">
                    <Button.ToolTip>
                        <TextBlock Text="Manual" Padding="6,2" FontSize="20"/>
                    </Button.ToolTip>
                    <TextBlock Text="📘" FontSize="32" HorizontalAlignment="Center"/>
                </Button>
            </StackPanel>
        </Border>



        <!-- 🌌 Khu hiển thị nội dung View -->
        <Border CornerRadius="10" Background="#2D2D2D" Margin="0,0,10,10">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="12" ShadowDepth="2" Opacity="0.4"/>
            </Border.Effect>
            <ContentControl Content="{Binding NavigationService.CurrentViewModel}" />
        </Border>
    </DockPanel>

</Window>
