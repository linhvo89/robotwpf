                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                    <Setter Property="Background" Value="#555555"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CloseOn}" Value="True">
                                                            <Setter Property="Background" Value="#D32F2F"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Content="FREE DRIVE"
        Command="{Binding RequestFreeDriveCommand}"
        Width="120" Height="42" FontSize="16" FontWeight="Bold" Foreground="White" Margin="5">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                    <Setter Property="Content" Value="BRAKE LOCK"/>
                                                    <Setter Property="Background" Value="#555555"/>

                                                    <Setter Property="IsEnabled" Value="False"/>
                                                    <Setter Property="Opacity" Value="0.5"/>

                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding EnableOn}" Value="True">
                                                            <Setter Property="IsEnabled" Value="True"/>
                                                            <Setter Property="Opacity" Value="1.0"/>
                                                        </DataTrigger>

                                                        <DataTrigger Binding="{Binding FreeDriveOn}" Value="True">
                                                            <Setter Property="Content" Value="FREE DRIVE"/>
                                                            <Setter Property="Background" Value="#2196F3"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
