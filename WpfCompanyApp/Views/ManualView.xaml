                                        <Button Width="120" Height="42" FontSize="16" FontWeight="Bold" Foreground="White">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                    <Setter Property="Content" Value="OPEN"/>
                                                    <Setter Property="Background" Value="#555555"/>
                                                    <Setter Property="Command" Value="{Binding RequestOpenCommand}"/>

                                                    <Style.Triggers>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding OpenOn}" Value="True"/>
                                                                <Condition Binding="{Binding EnableOn}" Value="False"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Content" Value="ENABLE"/>
                                                            <Setter Property="Background" Value="#FFD600"/>
                                                            <Setter Property="Command" Value="{Binding RequestEnableCommand}"/>
                                                        </MultiDataTrigger>

                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding OpenOn}" Value="True"/>
                                                                <Condition Binding="{Binding EnableOn}" Value="True"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Content" Value="DISABLE"/>
                                                            <Setter Property="Background" Value="#00C853"/>
                                                            <Setter Property="Command" Value="{Binding RequestDisableCommand}"/>
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <Button Content="CLOSE"
            Width="120" Height="42" FontSize="16" FontWeight="Bold" Foreground="White"
