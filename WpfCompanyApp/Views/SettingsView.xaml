                                               Foreground="#777777"/>
                                                                        <ComboBox Grid.Column="1"
                                              Grid.Row="4"
                                              ItemsSource="{Binding SpeedOptions}"
                                              SelectedItem="{Binding SpeedUnused, Mode=TwoWay}"
                                              Style="{StaticResource PrettyComboBox}"/>
                                        </Grid>
                                    </GroupBox>


                                    <!-- Air -->
                                    <GroupBox Header="Chọn thổi khí"
                              Grid.Column="1"
                              Style="{StaticResource DarkGroupBox}">
                                        <CheckBox Content="Thổi khí"
                                  Foreground="White"
                                  Margin="6"/>
                                    </GroupBox>

                                    <!-- System -->
                                    <GroupBox Header="System"
                              Grid.Column="2"
                              Style="{StaticResource DarkGroupBox}">
                                        <StackPanel>
                                            <CheckBox Content="SetSensor"
                                      Foreground="White"/>
                                            <Separator Margin="8"/>
                                            <CheckBox Content="WriteLog"
                                      Foreground="White"/>
                                        </StackPanel>
                                    </GroupBox>
                                </Grid>

                            </Grid>
                        </ScrollViewer>

                    </Grid>
                </TabItem>

            </TabControl>
        </Grid>
    </Grid>
</UserControl>
