<UserControl x:Class="WpfCompanyApp.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WpfCompanyApp.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
              xmlns:Release="clr-namespace:VMControls.WPF.Release;assembly=VMControls.WPF.Release"
              Language="en-US"
             mc:Ignorable="d"
             Background="#20232A">

    <!-- ================== 🔧 RESOURCES ================== -->
    <UserControl.Resources>
        <conv:GreaterThanZeroConverter x:Key="GreaterThanZeroConverter"/>
        <conv:Range01ValidationRule x:Key="Range01ValidationRule" />
        <conv:StringNullOrEmptyToVisibilityConverter x:Key="StringNullOrEmptyToVisibilityConverter"/>
        <conv:SliderValueToWidthConverter x:Key="SliderValueToWidthConverter"/>
        <conv:EnableTextConverter x:Key="EnableTextConverter"/>
        <conv:EnableButtonStyleConverter x:Key="EnableButtonStyleConverter"/>
        <Style x:Key="PrettyComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#5E5E5E"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Bd"
                            CornerRadius="8"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                                <Grid>
                                    <!-- Nội dung chọn -->
                                    <ContentPresenter Margin="4,0,28,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"/>

                                    <!-- Nút mũi tên -->
                                    <ToggleButton x:Name="DropDownToggle"
                                          Grid.Column="1"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="Transparent"
                                          BorderBrush="{x:Null}"
                                          HorizontalAlignment="Right"
                                          Width="24">
                                        <Path Data="M 0 0 L 4 4 L 8 0 Z"
                                      Width="8"
                                      Height="4"
                                      Stretch="Uniform"
                                      Fill="#E0E0E0"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                                    </ToggleButton>
                                </Grid>
                            </Border>

                            <!-- Popup dropdown -->
                            <Popup x:Name="PART_Popup"
                           Placement="Bottom"
                           IsOpen="{TemplateBinding IsDropDownOpen}"
                           AllowsTransparency="True"
                           Focusable="False"
                           PopupAnimation="Slide">
                                <Border CornerRadius="8"
                                Background="#333333"
                                BorderBrush="#5E5E5E"
                                BorderThickness="2">
                                    <ScrollViewer Margin="0,2,0,2"
                                          SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#9E9E9E"/>
                            </Trigger>

                            <!-- Focus -->
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#1E88E5"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="2.5"/>
                            </Trigger>

                            <!-- Disabled -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#777"/>
                                <Setter TargetName="Bd" Property="Background" Value="#444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <!-- Style cho từng item trong dropdown -->
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="Padding" Value="8,4"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="White"/>

                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#1E88E5"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#6A1B9A"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 💠 Button Style - Có hiệu ứng mượt -->
        <!-- Fixed Button Style: animate scale via RenderTransform property path -->
        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <!-- border is named and we will target its RenderTransform -->
                            <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            SnapsToDevicePixels="True">
                                <!-- RenderTransform is set on the Border -->
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Border.RenderTransform>

                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.25"/>
                                </Border.Effect>

                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>

                        <!-- Use ControlTemplate.Triggers: animate RenderTransform of 'border' by property path -->
                        <ControlTemplate.Triggers>
                            <!-- Hover: animate scale a bit and change background via Setter -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                     To="1.05"
                                                     Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                     To="1.05"
                                                     Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>

                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                     To="1"
                                                     Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                     To="1"
                                                     Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>

                                <!-- change background color (no animation) for reliability -->
                                <Setter TargetName="border" Property="Background" Value="#3399FF"/>
                            </Trigger>

                            <!-- Pressed: shrink and slightly reduce opacity -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                     To="0.96"
                                                     Duration="0:0:0.06"/>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                     To="0.96"
                                                     Duration="0:0:0.06"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                     To="1"
                                                     Duration="0:0:0.08"/>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                     To="1"
                                                     Duration="0:0:0.08"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox Style đẹp -->
        <Style x:Key="PrettyTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#5E5E5E"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>

            <!-- Template bo góc -->
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                            CornerRadius="8"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>

                        <!-- Trigger khi focus -->
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#1E88E5"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="2.5"/>
                            </Trigger>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#9E9E9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="BorderBrush" Value="Red"/>
                    <Setter Property="BorderThickness" Value="2"/>
                    <Setter Property="ToolTip"
                    Value="{Binding (Validation.Errors)[0].ErrorContent,
                                    RelativeSource={RelativeSource Self}}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 💚 Nút xanh lá (Save) -->
        <Style x:Key="ModernButton_Green" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#43A047"/>
        </Style>

        <!-- 💙 Nút xanh dương (Move) -->
        <Style x:Key="ModernButton_Blue" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#2196F3"/>
        </Style>

        <!-- ❤️ Nút đỏ (Delete) -->
        <Style x:Key="ModernButton_Red" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#E53935"/>
        </Style>
        <!-- ===== STYLE GROUPBOX ĐỒNG BỘ SETTING ===== -->
        <Style x:Key="DarkGroupBox" TargetType="GroupBox">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="8"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Border Background="#2F343F"
                        CornerRadius="10"
                        BorderBrush="#3C3C3C"
                        BorderThickness="1"
                        Padding="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- HEADER -->
                                <TextBlock Text="{TemplateBinding Header}"
                                   Foreground="#00E676"
                                   FontSize="17"
                                   FontWeight="Bold"
                                   Margin="4,0,0,10"/>

                                <!-- CONTENT -->
                                <ContentPresenter Grid.Row="1"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="9*"/>
            <ColumnDefinition Width="389*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ====== HEADER ====== -->
        <Border Grid.Row="0" Background="#007ACC" Margin="0,0,0,15" CornerRadius="0,0,10,10" Grid.ColumnSpan="2">
            <TextBlock Text="Setting"
                       FontSize="34"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center">
                <TextBlock.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.3"/>
                </TextBlock.Effect>
            </TextBlock>
        </Border>

        <!-- ====== MAIN CONTENT ====== -->
        <Grid Grid.Row="1" Grid.ColumnSpan="2">
            <TabControl x:Name="tabRobot"
                        
                        FontWeight="SemiBold"
                        Background="#20232A"
                        BorderBrush="#3C3C3C"
                        Foreground="#E0E0E0"
                        BorderThickness="1">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="MinHeight" Value="40"/>
                        <Setter Property="MinWidth" Value="150"/>
                        <Setter Property="Padding" Value="10,5"/>
                        <Setter Property="FontSize" Value="16"/>
                    </Style>

                </TabControl.Resources>


                <!-- ============= TAB 1: ROBOT POSITION MANAGEMENT ============= -->
                <TabItem Header="ROBOT POSITION MANAGEMENT">
                    <Grid Background="#20232A">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="420"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- JOB MANAGEMENT PANEL -->
                        <Border Grid.Column="0" Background="#2F343F" CornerRadius="10" Padding="15" Margin="0,0,15,0">
                            <StackPanel>
                                <TextBlock Text="JOB MANAGEMENT" FontSize="20" FontWeight="Bold" Foreground="#FFFFFF" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                                <DataGrid ItemsSource="{Binding Jobs}"
                                          SelectedItem="{Binding SelectedJob, Mode=TwoWay}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          IsReadOnly="False"
                                          HeadersVisibility="Column"
                                          Background="#2F343F"
                                          Foreground="#E0E0E0"
                                          BorderBrush="#3C3C3C"
                                          RowBackground="#2C2F33"
                                          AlternatingRowBackground="#32363F"
                                          SelectionMode="Single"
                                          SelectionUnit="FullRow"
                                          Margin="0,0,0,10">
                                    <DataGrid.Resources>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="#333"/>
                                            <Setter Property="Foreground" Value="#EEE"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Height" Value="28"/>
                                        </Style>
                                        <Style TargetType="DataGridRow">
                                            <Setter Property="Background" Value="#2F343F"/>
                                            <Setter Property="Foreground" Value="#EEE"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#007ACC"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.Resources>

                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="0.5*" />
                                        <DataGridTextColumn Header="Job Name" Binding="{Binding JobName}" Width="1.5*" />
                                        <DataGridTextColumn Header="Created Time" Binding="{Binding DatetimeJob, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="1.5*" />
                                        <DataGridTemplateColumn Header="Delete" Width="Auto">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="🗑 Delete"
                                                            Command="{Binding DataContext.DeleteJobCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource ModernButton_Red}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                              
                                    <Button Content="Add Job" FontSize="18" Command="{Binding AddJobCommand}" Width="80" Height="40"  Style="{StaticResource ModernButton_Green}" Margin="5,0,0,0"/>
                                    <Button Content="Reload"  FontSize="18" Command="{Binding LoadJobsCommand}" Width="80" Height="40"  Style="{StaticResource ModernButton_Blue}" Margin="5,0,0,0"/>
                                    <Button Content="Save Job"  FontSize="18" Command="{Binding SaveJobCommand}" Width="80" Height="40"  Style="{StaticResource ModernButton_Blue}" Margin="5,0,0,0"/>
                              </StackPanel>

                                <Border BorderThickness="0,1,0,0" BorderBrush="#3C3C3C" Margin="0,10,0,10"/>

                                <!-- TRIGGER CAMERA SECTION -->
                                <TextBlock Text="TRIGGER CAMERA" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" HorizontalAlignment="Center" Margin="0,15,0,10"/>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                                    <Button Content="📷 Trigger" 
                                            FontSize="16" 
                                            Command="{Binding TriggerCameraReqCommand}" 
                                            Width="100" 
                                            Height="40"
                                            Style="{StaticResource ModernButton_Blue}" 
                                            Margin="0,0,8,0"/>

                                    <TextBlock Text="{Binding Data.NumTriggerCamera, StringFormat='Found: {0} positions'}" 
                                               Foreground="#E0E0E0" 
                                               VerticalAlignment="Center" 
                                               FontSize="14"
                                               Margin="0,0,8,0"/>

                                    <!-- ComboBox chọn namecalib (tool1, tool2, tool3) -->
                                    
                                    <ComboBox ItemsSource="{Binding CalibToolList}"
                                              SelectedItem="{Binding Data.SelectedCalibTool, Mode=TwoWay}"
                                              Width="100"
                                              Height="36"
                                              FontSize="14"
                                              Style="{StaticResource PrettyComboBox}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,0,0"/>
                                </StackPanel>


                                <!-- DYNAMIC SAVE POSITION BUTTONS -->
                                <ItemsControl ItemsSource="{Binding Data.RobotPositionList}" Margin="0,0,0,10">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding PositionName, StringFormat='💾 Save {0}'}"
                                                    Command="{Binding DataContext.SavePositionReqCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Width="130" 
                                                    Height="36" 
                                                    Margin="4">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource ModernButton_Green}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsStatus}" Value="True">
                                                                <Setter Property="Background" Value="#007BFF"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <!-- NEW: SaveAll -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="💾 Save All"
                                        FontSize="16"
                                        Command="{Binding SaveAllPositionsReqCommand}"
                                        Width="120"
                                        Height="40"
                                        Margin="0,0,8,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource ModernButton_Green}">
                                                <Setter Property="IsEnabled" Value="False"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Data.NumTriggerCamera, Converter={StaticResource GreaterThanZeroConverter}}" Value="True">
                                                        <Setter Property="IsEnabled" Value="True"/>
                                                    </DataTrigger>
                                                    <!-- Đổi màu khi SaveAll thành công -->
                                                    <DataTrigger Binding="{Binding Data.IsSaveAllSuccess}" Value="True">
                                                        <Setter Property="Background" Value="#007BFF"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <Button Content="📄 Export TXT"
                                    FontSize="16"
                                    Command="{Binding ExportCalibPointsToTxtCommand}"
                                    Width="130"
                                    Height="40"
                                    Style="{StaticResource ModernButton_Blue}"/>
                                </StackPanel>

                            </StackPanel>
                        </Border>

                        <!-- ROBOT POSITION PANEL -->
                        <Border Grid.Column="1" Background="#2F343F" CornerRadius="2" Padding="5">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid x:Name="vmProduce" Grid.Row="0"  Margin="0,0,0,0">
                                
                                        <Release:VmMainViewConfigControl  x:Name="vmMainViewConfigControl" x:FieldModifier="public"   />

                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- ============= TAB 2: SETTING ROBOT TRAJECTORY ============= -->
                <TabItem Header="SETTING ROBOT TRAJECTORY" >
                    <!-- ==== BUTTON SECTION ==== -->
                    <!-- ==== BUTTON SECTION ==== -->
                    <!-- ==== BUTTON SECTION ==== -->
                    <Grid Grid.Row="1"
                      Margin="0,25,0,0"
                      Background="#1E1E1E">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <!-- FORWARD chiếm 2/3 -->
                            <ColumnDefinition Width="2.5*"/>

                            <!-- HOME + WORKSPACE chiếm 1/3 -->
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- STYLE CHUNG -->
                        <Grid.Resources>
                            <Style TargetType="Button">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontSize" Value="14"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Margin" Value="4"/>
                                <Setter Property="Padding" Value="5,3"/>
                                <Setter Property="Height" Value="36"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Foreground" Value="#F5F5F5"/>
                            </Style>

                            <Style TargetType="CheckBox">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="4"/>
                            </Style>
                        </Grid.Resources>

                        <!-- ================= LEFT: FORWARD TRAJECTORY ================= -->
                        <Border Grid.Row="0"
                        Grid.Column="0"
                        Grid.RowSpan="2"
                        Background="#2D2D2D"
                        CornerRadius="10"
                        Padding="15"
                        Margin="10"
                        MaxHeight="600">

                            <Border.Effect>
                                <DropShadowEffect Color="Black"
                              BlurRadius="12"
                              ShadowDepth="3"
                              Opacity="0.25"/>
                            </Border.Effect>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="FORWARD TRAJECTORY"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="#E0E0E0"
                   Margin="15,10,0,10"/>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <TextBlock Text="Job: "
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#E0E0E0"
                       Margin="15,10,0,10"/>

                                        <TextBlock Text="{Binding SelectedJob.JobName}"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#E0E0E0"
                       Margin="15,10,0,10"/>
                                    </StackPanel>
                                </Grid>

                                <!-- FORWARD POINTS TABLE -->
                                <DataGrid Grid.Row="1"
                                  Margin="0"
                                  Padding="0"
                                  ItemsSource="{Binding ForwardPoints}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserResizeRows="False"
                                  CanUserSortColumns="False"
                                  RowHeight="42"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  EnableRowVirtualization="True"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  Background="#32373E"
                                  Foreground="#E0E0E0"
                                  BorderBrush="Transparent"
                                  BorderThickness="0"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#424A52">

                                    <DataGrid.Resources>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="#1E242B"/>
                                            <Setter Property="Foreground" Value="#4FC3F7"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="FontSize" Value="12"/>
                                            <Setter Property="Padding" Value="8,6"/>
                                            <Setter Property="BorderThickness" Value="0,0,1,2"/>
                                            <Setter Property="BorderBrush" Value="#0D47A1"/>
                                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        </Style>

                                        <Style TargetType="DataGridRow">
                                            <Setter Property="Background" Value="#32373E"/>
                                            <Setter Property="Foreground" Value="#E0E0E0"/>
                                            <Setter Property="Height" Value="42"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#3F464E"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#1565C0"/>
                                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>

                                        <Style TargetType="DataGridCell">
                                            <Setter Property="Padding" Value="6,0"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.Resources>

                                    <DataGrid.Columns>

                                        <!-- Point Index -->
                                        <DataGridTextColumn Header="#" 
                                                            Binding="{Binding Index}" 
                                                            Width="40"
                                                            ElementStyle="{StaticResource {x:Type TextBlock}}" 
                                                            FontSize="12"
                                                            FontWeight="Bold"
                                                            Foreground="#FFD54F"/>

                                        <!-- SAVE POSITION -->
                                        <DataGridTemplateColumn Header="💾 Save robot position" Width="120">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="💾" 
                                                            Padding="4,2" 
                                                            Height="30" 
                                                            Width="40"
                                                            Background="#43A047" 
                                                            Foreground="White" 
                                                            FontSize="14"
                                                            BorderThickness="0"
                                                            Cursor="Hand"
                                                            Command="{Binding DataContext.SaveForwardPointCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding Index}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <!-- MOVE POSITION -->
                                        <DataGridTemplateColumn Header="🤖 Move" Width="85">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="🤖" 
                                                            Padding="4,2" 
                                                            Height="30" 
                                                            Width="40"
                                                            Background="#1E88E5" 
                                                            Foreground="White" 
                                                            FontSize="14"
                                                            BorderThickness="0"
                                                            Cursor="Hand"
                                                            Command="{Binding DataContext.MoveForwardPointCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding Index}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                       

                                        <!-- SPEED VALUE -->
                                        <DataGridTextColumn Header="Speed(mm/s)" 
                                                            Binding="{Binding Velocity, Mode=TwoWay}" 
                                                            Width="95"
                                                            FontSize="12"/>

                                        <!-- MOVE TYPE -->
                                        <DataGridTemplateColumn Header="Move Type" Width="100">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ComboBox ItemsSource="{Binding DataContext.MoveTypeOptions, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                              SelectedItem="{Binding MoveType, Mode=TwoWay}"
                                                              Style="{StaticResource PrettyComboBox}"
                                                              Height="28" 
                                                              Margin="0"
                                                              Padding="4,2"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <!-- CAMERA ID -->
                                        <DataGridTextColumn Header="📷 Cam ID" 
                                                            Binding="{Binding IdCam, Mode=TwoWay}" 
                                                            Width="85"
                                                            FontSize="12"/>

                                        <!-- ENABLE CAMERA -->
                                        <DataGridCheckBoxColumn Header="Enable Cam" 
                                                                Binding="{Binding EnableCam, Mode=TwoWay}" 
                                                                Width="85"/>

                                        <!-- ENABLE POINT -->
                                        <DataGridCheckBoxColumn Header="Enable" 
                                                                Binding="{Binding Enable, Mode=TwoWay}" 
                                                                Width="85"/>

                                        <!-- NOTES -->
                                        <DataGridTemplateColumn Header="Notes" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Note}"
                       Background="#FFF3CD"
                       Foreground="Black"
                       Padding="5"
                       FontSize="12"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>

                                            <DataGridTemplateColumn.CellEditingTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding Note, Mode=TwoWay}"
                                                     Background="#FFF3CD"
                                                     Foreground="Black"
                                                     BorderThickness="0"
                                                     Padding="5"
                                                     FontSize="12"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellEditingTemplate>
                                        </DataGridTemplateColumn>
                                        <!-- SAVE Update -->
                                        <DataGridTemplateColumn Header="🔧 Update" Width="85">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="💾" 
                                                 Padding="4,2" 
                                                 Height="30" 
                                                 Width="40"
                                                 Background="#7B1FA2" 
                                                 Foreground="White" 
                                                 FontSize="14"
                                                 BorderThickness="0"
                                                 Cursor="Hand"
                                                 Command="{Binding DataContext.SaveForwardVelocityCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                 CommandParameter="{Binding Index}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                            </Grid>
                        </Border>

                        <!-- ================= RIGHT TOP: HOME POSITION ================= -->
                        <Border Grid.Row="0"
            Grid.Column="1"
            Background="#2D2D2D"
            CornerRadius="10"
            Padding="15"
            Margin="10">

                            <Border.Effect>
                                <DropShadowEffect Color="Black"
                              BlurRadius="12"
                              ShadowDepth="3"
                              Opacity="0.25"/>
                            </Border.Effect>

                            <StackPanel>
                                <TextBlock Text="HOME POSITION"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#E0E0E0"
                       Margin="0,0,0,15"
                       HorizontalAlignment="Center"/>

                                <UniformGrid Rows="1"
                         Columns="2"
                         HorizontalAlignment="Center">

                                    <Button Content="💾 Save Home"
                        Width="130"
                        Background="#D17C00"
                        Command="{Binding SaveHomeCommand}"/>

                                    <Button Content="🏠 Move Home"
                        Width="130"
                        Background="#A45C00"
                        Command="{Binding MoveHomeCommand}"/>

                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <!-- ================= RIGHT BOTTOM: WORKSPACE POINTS ================= -->
                        <Border Grid.Row="1"
            Grid.Column="1"
            Background="#2D2D2D"
            CornerRadius="10"
            Padding="15"
            Margin="10">

                            <Border.Effect>
                                <DropShadowEffect Color="Black"
                              BlurRadius="12"
                              ShadowDepth="3"
                              Opacity="0.25"/>
                            </Border.Effect>

                            <StackPanel HorizontalAlignment="Center">

                                <TextBlock Text="WORKSPACE POINTS"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#E0E0E0"
                       Margin="0,0,0,8"
                       HorizontalAlignment="Center"/>

                                <TextBlock Text="6 điểm giới hạn không gian làm việc"
                       FontSize="13"
                       Foreground="#B0B0B0"
                       Margin="0,0,0,15"
                       TextAlignment="Center"/>

                                <Grid Width="280"
                  Margin="0,0,0,8">

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                           Text="SAVE"
                           Foreground="#E0E0E0"
                           FontWeight="Bold"
                           FontSize="14"
                           HorizontalAlignment="Center"/>

                                    <TextBlock Grid.Column="1"
                           Text="MOVE"
                           Foreground="#E0E0E0"
                           FontWeight="Bold"
                           FontSize="14"
                           HorizontalAlignment="Center"/>
                                </Grid>

                                <UniformGrid Rows="6"
                         Columns="2"
                         Width="280"
                         HorizontalAlignment="Center">

                                    <Button Content="💾 P1" Width="130" Height="40" Background="#388E3C"
                        Command="{Binding SaveWorkspacePointCommand}" CommandParameter="1"/>

                                    <Button Content="🤖 P1" Width="130" Height="40" Background="#1E88E5"
                        Command="{Binding MoveWorkspacePointCommand}" CommandParameter="1"/>

                                    <Button Content="💾 P2" Width="130" Height="40" Background="#388E3C"
                        Command="{Binding SaveWorkspacePointCommand}" CommandParameter="2"/>

                                    <Button Content="🤖 P2" Width="130" Height="40" Background="#1E88E5"
                        Command="{Binding MoveWorkspacePointCommand}" CommandParameter="2"/>

                                    <Button Content="💾 P3" Width="130" Height="40" Background="#388E3C"
                        Command="{Binding SaveWorkspacePointCommand}" CommandParameter="3"/>

                                    <Button Content="🤖 P3" Width="130" Height="40" Background="#1E88E5"
                        Command="{Binding MoveWorkspacePointCommand}" CommandParameter="3"/>

                                    <Button Content="💾 P4" Width="130" Height="40" Background="#388E3C"
                        Command="{Binding SaveWorkspacePointCommand}" CommandParameter="4"/>

                                    <Button Content="🤖 P4" Width="130" Height="40" Background="#1E88E5"
                        Command="{Binding MoveWorkspacePointCommand}" CommandParameter="4"/>

                                    <Button Content="💾 P5" Width="130" Height="40" Background="#388E3C"
                        Command="{Binding SaveWorkspacePointCommand}" CommandParameter="5"/>

                                    <Button Content="🤖 P5" Width="130" Height="40" Background="#1E88E5"
                        Command="{Binding MoveWorkspacePointCommand}" CommandParameter="5"/>

                                    <Button Content="💾 P6" Width="130" Height="40" Background="#388E3C"
                        Command="{Binding SaveWorkspacePointCommand}" CommandParameter="6"/>

                                    <Button Content="🤖 P6" Width="130" Height="40" Background="#1E88E5"
                        Command="{Binding MoveWorkspacePointCommand}" CommandParameter="6"/>

                                </UniformGrid>
                            </StackPanel>
                        </Border>

                    </Grid>
                </TabItem>

                <!-- ============= TAB 3: SETTING ROBOT sensor ============= -->
                <TabItem Header="SETTING ROBOT SENSOR">
                    <Grid Background="#20232A">

                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Grid Margin="20">

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- ================= ROW 1 ================= -->
                                <Grid Grid.Row="0" Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.2*"/>
                                        <ColumnDefinition Width="1.2*"/>
                                        <ColumnDefinition Width="1.6*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Select Basket -->
                                    <GroupBox Header="Select Basket"
                              Style="{StaticResource DarkGroupBox}">
                                        <StackPanel>
                                            <CheckBox Content="Basket 1" Foreground="White"/>
                                            <CheckBox Content="Basket 2" Foreground="White"/>
                                        </StackPanel>
                                    </GroupBox>

                                    <!-- Select Head -->
                                    <GroupBox Header="Select Head"
                              Grid.Column="1"
                              Style="{StaticResource DarkGroupBox}">
                                        <StackPanel>
                                            <CheckBox Content="Suction head 1" Foreground="White"/>
                                            <CheckBox Content="Suction head 2" Foreground="White"/>
                                            <CheckBox Content="Suction head 3" Foreground="White"/>
                                        </StackPanel>
                                    </GroupBox>

                                    <!-- Sensor Full Work -->
                                    <GroupBox Header="Sensor Full Work"
                              Grid.Column="2"
                              Style="{StaticResource DarkGroupBox}">
                                        <ComboBox Style="{StaticResource PrettyComboBox}"
                                  Margin="4"/>
                                    </GroupBox>
                                </Grid>

                                <!-- ================= ROW 2 ================= -->
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2.2*"/>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="1*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Speed -->
                                    <GroupBox Header="Tốc độ robot"
                                     Style="{StaticResource DarkGroupBox}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2.8*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Tốc độ Robot chụp ảnh -->
                                            <TextBlock Text="Tốc độ Robot chụp ảnh"
                                               Foreground="#CCCCCC"/>
                                                                        <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding SpeedOptions}"
                                              SelectedItem="{Binding SpeedCapture, Mode=TwoWay}"
                                              Style="{StaticResource PrettyComboBox}"/>

                                            <!-- Tốc độ Robot chờ hút -->
                                            <TextBlock Text="Tốc độ Robot chờ hút"
                                                Grid.Row="1"
                                                Foreground="#CCCCCC"/>
                                                                        <ComboBox Grid.Column="1"
                                                Grid.Row="1"
                                                ItemsSource="{Binding SpeedOptions}"
                                                SelectedItem="{Binding SpeedWaitPick, Mode=TwoWay}"
                                                Style="{StaticResource PrettyComboBox}"/>

                                            <!-- Tốc độ Robot đi lên vị trí thả -->
                                            <TextBlock Text="Tốc độ Robot đi lên vị trí thả"
                                               Grid.Row="2"
                                               Foreground="#CCCCCC"/>
                                                                        <ComboBox Grid.Column="1"
                                              Grid.Row="2"
                                              ItemsSource="{Binding SpeedOptions}"
                                              SelectedItem="{Binding SpeedMoveUp, Mode=TwoWay}"
                                              Style="{StaticResource PrettyComboBox}"/>

                                            <!-- Tốc độ Robot quay về sau khi thả -->
                                            <TextBlock Text="Tốc độ Robot quay về sau khi thả"
                                               Grid.Row="3"
                                               Foreground="#CCCCCC"/>
                                                                        <ComboBox Grid.Column="1"
                                              Grid.Row="3"
                                              ItemsSource="{Binding SpeedOptions}"
                                              SelectedItem="{Binding SpeedReturn, Mode=TwoWay}"
                                              Style="{StaticResource PrettyComboBox}"/>

                                            <!-- Chưa dùng -->
                                            <TextBlock Text="Chưa dùng đến"
                                                Grid.Row="4"
                                               Foreground="#777777"/>
                                                                        <ComboBox Grid.Column="1"
                                              Grid.Row="4"
                                              ItemsSource="{Binding SpeedOptions}"
                                              SelectedItem="{Binding SpeedUnused, Mode=TwoWay}"
                                              Style="{StaticResource PrettyComboBox}"/>
                                        </Grid>
                                    </GroupBox>


                                    <!-- Air -->
                                    <GroupBox Header="Chọn thổi khí"
                              Grid.Column="1"
                              Style="{StaticResource DarkGroupBox}">
                                        <CheckBox Content="Thổi khí"
                                  Foreground="White"
                                  Margin="6"/>
                                    </GroupBox>

                                    <!-- System -->
                                    <GroupBox Header="System"
                              Grid.Column="2"
                              Style="{StaticResource DarkGroupBox}">
                                        <StackPanel>
                                            <CheckBox Content="SetSensor"
                                      Foreground="White"/>
                                            <Separator Margin="8"/>
                                            <CheckBox Content="WriteLog"
                                      Foreground="White"/>
                                        </StackPanel>
                                    </GroupBox>
                                </Grid>

                            </Grid>
                        </ScrollViewer>

                    </Grid>
                </TabItem>

            </TabControl>
        </Grid>
    </Grid>
</UserControl>
